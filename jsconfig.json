{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    }
  },
  "include": ["src/**/*.js", "src/**/*.d.ts", "tests/**/*.js", "pipeline/**/*.mjs", "scripts/**/*.mjs"],
  "exclude": ["src/vendor/**", "node_modules", "dist"]
}
